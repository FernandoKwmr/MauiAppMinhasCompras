<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NovoProduto"
             Title="NovoProduto">
    <VerticalStackLayout>
        <Label 
            Text="Novo Produto"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />


        <Frame Margin="20" Padding="10">
            <Grid ColumnDefinitions="*"
              RowDefinitions="Auto, Auto">

                <Label Grid.Row="0" Grid.Column="0" Text="Descrição:" />
                <Label Grid.Row="1" Grid.Column="0" Text="Quantidade:" />
                <Label Grid.Row="2" Grid.Column="0" Text="Preço:" />


                <Label Grid.Row="0" Grid.Column="0" 
                       Text="{Binding NomeEvento}"
                       TextColor="{StaticResource Primary}" />

                <Label Grid.Row="1" Grid.Column="0" 
                       Text="{Binding LocalEvento}"
                       TextColor="{StaticResource Primary}" />

                <Label Grid.Row="2" Grid.Column="0" 
                        Text="{Binding QntParticipantes}"
                        TextColor="{StaticResource Primary}" />

            </Grid>
        </Frame>

    </VerticalStackLayout>

</ContentPage>